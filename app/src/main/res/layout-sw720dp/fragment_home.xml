<?xml version="1.0" encoding="utf-8"?>
<!-- TV/Tablet layout: 2 panel — grup kiri, channel kanan -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Top AppBar -->
    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@color/bg_surface">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OrbixTV"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginEnd="20dp" />

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_v2"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_secondary"
                android:importantForAccessibility="no" />

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:iconifiedByDefault="false"
                app:queryHint="@string/search_hint_tv"
                app:searchIcon="@null"
                android:background="@android:color/transparent"
                app:queryBackground="@android:color/transparent"
                app:closeIcon="@drawable/ic_close"
                android:focusable="true"
                android:nextFocusDown="@id/rv_groups" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_channel_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Refresh playlist"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="@string/settings_description"
            android:focusable="true" />

    </LinearLayout>

    <!-- Divider bawah AppBar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Warning banner -->
    <TextView
        android:id="@+id/tv_playlist_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="@string/playlist_warning_tv"
        android:textColor="#FFAA44"
        android:textSize="13sp"
        android:background="@drawable/bg_warning_banner"
        android:visibility="gone" />

    <!-- Konten utama 2-panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Panel kiri: Daftar Grup -->
        <LinearLayout
            android:layout_width="248dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/bg_surface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KATEGORI"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <!-- Skeleton shimmer panel kiri saat loading -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="2dp">

                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_skeleton"/>

                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_groups"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingVertical="6dp"
                android:focusable="true"
                android:descendantFocusability="afterDescendants"
                android:nextFocusRight="@id/rv_search"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Divider vertikal -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <!-- Panel kanan: Daftar Channel -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_search_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Skeleton panel kanan saat search -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/shimmer_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp">

                        <include layout="@layout/item_channel_skeleton" />
                        <include layout="@layout/item_channel_skeleton" />
                        <include layout="@layout/item_channel_skeleton" />

                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_search"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone"
                    android:focusable="true"
                    android:nextFocusLeft="@id/rv_groups" />
            </LinearLayout>

            <!-- Empty state panel kanan -->
            <LinearLayout
                android:id="@+id/empty_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺"
                    android:textSize="56sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/select_category_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:gravity="center" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
