<?xml version="1.0" encoding="utf-8"?>
<!-- TV item_channel: lebih besar, teks lebih besar, highlight focus D-pad -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:focusable="true"
    android:clickable="true"
    android:defaultFocusHighlightEnabled="false"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <!-- Logo lebih besar untuk TV -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_tv_placeholder"
            android:background="@drawable/bg_logo"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <!-- Nama channel lebih besar untuk keterbacaan dari jauh -->
            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Channel Name"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Group"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_stream_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HLS"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:layout_marginEnd="12dp" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_play_arrow"
            android:tint="@color/text_secondary"
            android:importantForAccessibility="no" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
