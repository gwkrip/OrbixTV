<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/channel_item_margin_h"
    android:layout_marginVertical="@dimen/channel_item_margin_v"
    android:focusable="true"
    android:clickable="true"
    android:defaultFocusHighlightEnabled="false"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="@dimen/channel_card_radius"
    app:cardElevation="0dp">

    <!--
        Inner LinearLayout: background selector_tv_focus (transparent default,
        biru saat fokus D-pad). Tidak double-paint karena default = transparent.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/channel_item_padding_h"
        android:paddingVertical="@dimen/channel_item_padding_v"
        android:background="@drawable/selector_tv_focus"
        android:duplicateParentState="true">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="@dimen/channel_logo_size"
            android:layout_height="@dimen/channel_logo_size"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_tv_placeholder"
            android:background="@drawable/bg_logo"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Channel Name"
                android:textColor="@color/white"
                android:textSize="@dimen/text_channel_name"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Group"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_group_name"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_stream_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HLS"
            android:textColor="@color/accent_blue"
            android:textSize="@dimen/text_badge"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:layout_marginEnd="10dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_play_arrow"
            android:tint="#44FFFFFF"
            android:importantForAccessibility="no"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
