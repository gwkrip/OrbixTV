<?xml version="1.0" encoding="utf-8"?>
<!-- Skeleton TV — dimensi HARUS sinkron dengan layout-sw720dp/item_channel.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/channel_item_margin_h"
    android:layout_marginVertical="@dimen/channel_item_margin_v"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="@dimen/channel_card_radius"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/channel_item_padding_h"
        android:paddingVertical="@dimen/channel_item_padding_v">

        <!-- Logo placeholder: ukuran & shape sama dengan iv_logo di TV item_channel -->
        <View
            android:layout_width="@dimen/channel_logo_size"
            android:layout_height="@dimen/channel_logo_size"
            android:background="@drawable/bg_skeleton_circle"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <View
                android:layout_width="160dp"
                android:layout_height="15dp"
                android:background="@drawable/bg_skeleton"/>

            <View
                android:layout_width="90dp"
                android:layout_height="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_skeleton"
                android:alpha="0.55"/>
        </LinearLayout>

        <!-- Badge placeholder -->
        <View
            android:layout_width="44dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_skeleton"
            android:alpha="0.45"/>

        <!-- Play arrow placeholder -->
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_skeleton"
            android:alpha="0.2"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
