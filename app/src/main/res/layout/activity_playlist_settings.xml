<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:background="@color/bg_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/playlist_settings"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold" />

    </LinearLayout>

    <!-- Thin divider under top bar -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#1A2A3A"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- ── Active Source Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_source_active"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="●"
                    android:textColor="@color/accent_blue"
                    android:textSize="10sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_current_source"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Sumber aktif: URL Default"
                    android:textColor="@color/accent_blue"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- ── Playlist URL Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_section_card"
                android:layout_marginBottom="12dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="URL Playlist M3U"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Masukkan URL file .m3u atau .m3u8 yang dapat diakses publik."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp" />

                <!-- URL Input -->
                <EditText
                    android:id="@+id/et_playlist_url"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/playlist_url_hint"
                    android:inputType="textUri"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="14dp"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:layout_marginBottom="14dp" />

                <!-- Apply Button -->
                <Button
                    android:id="@+id/btn_apply"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Terapkan Playlist"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:backgroundTint="@color/accent_blue"
                    android:layout_marginBottom="10dp" />

                <!-- Reset Button -->
                <Button
                    android:id="@+id/btn_reset"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Reset ke URL Default"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    style="?attr/materialButtonOutlinedStyle"
                    android:backgroundTint="@android:color/transparent"
                    android:strokeColor="@color/text_secondary" />

            </LinearLayout>

            <!-- ProgressBar (loading state) -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent_blue"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Error Card -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:textColor="#FFAA44"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:background="@drawable/bg_error_card"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- ── Tips Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_section_card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/tips_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <!-- Tips list items -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                        android:text="•" android:textColor="@color/accent_blue" android:textSize="14sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:text="File .m3u atau .m3u8 yang dapat diakses publik"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                        android:text="•" android:textColor="@color/accent_blue" android:textSize="14sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:text="URL dari layanan IPTV berbayar (Xtream Codes, dll.)"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                        android:text="•" android:textColor="@color/accent_blue" android:textSize="14sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:text="GitHub raw file URL atau Google Drive direct link"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                        android:text="•" android:textColor="@color/accent_blue" android:textSize="14sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:text="Jika URL gagal, app otomatis kembali ke playlist bawaan"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ── Support Section ── -->
            <LinearLayout
                android:id="@+id/btn_support"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:background="@drawable/bg_support_button"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☕"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Dukung Pengembang"
                            android:textColor="#66CC66"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Traktir kopi di Saweria"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_down"
                    android:rotation="-90"
                    android:tint="#66CC66"
                    android:importantForAccessibility="no" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
