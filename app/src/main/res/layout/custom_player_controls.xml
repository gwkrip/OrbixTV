<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_player_controls_bar"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">

        <!-- Saluran sebelumnya -->
        <ImageButton
            android:id="@+id/btn_prev_channel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#CCFFFFFF"
            android:contentDescription="@string/prev_channel" />

        <!-- Play / Pause — sedikit lebih besar dengan latar lingkaran -->
        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_play_button"
            android:src="@drawable/ic_play_arrow"
            android:tint="@color/white"
            android:padding="12dp" />

        <!-- Saluran berikutnya -->
        <ImageButton
            android:id="@+id/btn_next_channel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_down"
            android:rotation="-90"
            android:tint="#CCFFFFFF"
            android:contentDescription="@string/next_channel" />

        <!-- LIVE badge — styled dengan border merah -->
        <TextView
            android:id="@+id/tv_live_badge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="● LIVE"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_live_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center"
            android:maxWidth="72dp"
            android:visibility="gone" />

        <!-- Spacer saat LIVE hidden -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@id/exo_fullscreen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_fullscreen"
            android:tint="#CCFFFFFF" />
    </LinearLayout>

</LinearLayout>
