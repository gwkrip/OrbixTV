<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_player_controls_bar"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp">

        <!-- Previous channel -->
        <ImageButton
            android:id="@+id/btn_prev_channel"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#CCFFFFFF"
            android:contentDescription="@string/prev_channel" />

        <!-- Play / Pause -->
        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_play_button"
            android:src="@drawable/ic_play_arrow"
            android:tint="@color/white"
            android:padding="14dp" />

        <!-- Next channel -->
        <ImageButton
            android:id="@+id/btn_next_channel"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_down"
            android:rotation="-90"
            android:tint="#CCFFFFFF"
            android:contentDescription="@string/next_channel" />

        <!-- LIVE badge -->
        <TextView
            android:id="@+id/tv_live_badge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="● LIVE"
            android:textColor="#FF4757"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_live_badge"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp"
            android:gravity="center"
            android:maxWidth="72dp"
            android:letterSpacing="0.06"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@id/exo_fullscreen"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_fullscreen"
            android:tint="#CCFFFFFF" />
    </LinearLayout>

</LinearLayout>
