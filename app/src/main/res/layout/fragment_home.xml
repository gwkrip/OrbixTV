<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <!-- Top row: app name + channel count + action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="21sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tv_channel_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loading"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />

                <ImageButton
                    android:id="@+id/btn_refresh"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_refresh"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/text_secondary"
                    android:contentDescription="Refresh playlist"
                    android:layout_marginStart="2dp" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_settings"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@string/settings_description" />

                <ImageButton
                    android:id="@+id/btn_sort_filter"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_down"
                    android:rotation="-90"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@string/sort_filter_title"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- Playlist warning banner -->
            <TextView
                android:id="@+id/tv_playlist_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="9dp"
                android:text="@string/playlist_warning"
                android:textColor="#FFAA44"
                android:textSize="12sp"
                android:background="@drawable/bg_warning_banner"
                android:visibility="gone" />

            <!-- Search bar — styled dengan bg_search_v2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_v2"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_secondary"
                    android:importantForAccessibility="no" />

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/search_view"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:iconifiedByDefault="false"
                    app:queryHint="@string/search_hint"
                    app:searchIcon="@null"
                    app:queryBackground="@android:color/transparent"
                    app:closeIcon="@drawable/ic_close"
                    android:background="@android:color/transparent" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Skeleton shimmer saat playlist loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp">

                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />
                <include layout="@layout/item_group_skeleton" />

            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_groups"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:clipToPadding="false"
            android:paddingBottom="72dp"
            android:visibility="gone" />

        <!-- Panel pencarian -->
        <LinearLayout
            android:id="@+id/search_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_search_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Skeleton saat menunggu hasil search (debounce 300ms) -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp">

                    <include layout="@layout/item_channel_skeleton" />
                    <include layout="@layout/item_channel_skeleton" />
                    <include layout="@layout/item_channel_skeleton" />

                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_search"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="72dp" />
        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
