<?xml version="1.0" encoding="utf-8"?>
<!-- item_channel.xml — shared phone + TV -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="3dp"
    android:focusable="true"
    android:clickable="true"
    android:defaultFocusHighlightEnabled="false"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:paddingVertical="10dp">

        <!-- Logo dengan status dot overlay -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_tv_placeholder"
                android:background="@drawable/bg_logo_circle"
                android:padding="7dp" />

            <View
                android:id="@+id/v_status_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="1dp"
                android:background="@drawable/bg_status_dot" />
        </FrameLayout>

        <!-- Nama & Grup -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Channel Name"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Group"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Stream type badge -->
        <TextView
            android:id="@+id/tv_stream_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HLS"
            android:textColor="@color/accent_blue"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_badge_hls"
            android:paddingHorizontal="7dp"
            android:paddingVertical="4dp"
            android:letterSpacing="0.04" />

        <!-- Play chevron -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_play_arrow"
            android:tint="#44FFFFFF"
            android:importantForAccessibility="no" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
