<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/channel_item_margin_h"
    android:layout_marginVertical="@dimen/channel_item_margin_v"
    android:focusable="true"
    android:clickable="true"
    android:defaultFocusHighlightEnabled="false"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="@dimen/channel_card_radius"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/channel_item_padding_h"
        android:paddingEnd="14dp"
        android:paddingVertical="@dimen/channel_item_padding_v">

        <!-- Logo dengan status dot overlay -->
        <FrameLayout
            android:layout_width="@dimen/channel_logo_size"
            android:layout_height="@dimen/channel_logo_size">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_tv_placeholder"
                android:background="@drawable/bg_logo_circle"
                android:padding="8dp" />

            <View
                android:id="@+id/v_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="1dp"
                android:background="@drawable/bg_status_dot" />
        </FrameLayout>

        <!-- Nama & Grup -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Channel Name"
                android:textColor="@color/white"
                android:textSize="@dimen/text_channel_name"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Group"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Stream type badge -->
        <TextView
            android:id="@+id/tv_stream_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HLS"
            android:textColor="@color/accent_blue"
            android:textSize="@dimen/text_badge"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_badge_hls"
            android:paddingHorizontal="7dp"
            android:paddingVertical="4dp"
            android:letterSpacing="0.04" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
