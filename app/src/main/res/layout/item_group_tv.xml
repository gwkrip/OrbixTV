<?xml version="1.0" encoding="utf-8"?>
<!-- item_group_tv.xml: dipakai TvGroupAdapter di panel kiri TV -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/group_header_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="14dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="2dp"
    android:focusable="true"
    android:clickable="true"
    android:defaultFocusHighlightEnabled="false"
    android:background="@drawable/selector_tv_group_focus">

    <TextView
        android:id="@+id/tv_group_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="🇮🇩 INDONESIA"
        android:textColor="@color/white"
        android:textSize="@dimen/text_group_name"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_channel_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="24"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:background="@drawable/bg_count_pill"
        android:paddingHorizontal="7dp"
        android:paddingVertical="3dp" />

</LinearLayout>
