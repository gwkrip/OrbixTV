<?xml version="1.0" encoding="utf-8"?>
<!-- Skeleton overlay untuk PlayerActivity saat stream buffering -->
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmer_player"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:shimmer_base_color="#1A1A1A"
    app:shimmer_highlight_color="#2E2E2E"
    app:shimmer_duration="1400"
    android:background="#000000"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo channel placeholder (lingkaran besar di tengah) -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_skeleton_circle" />

        <!-- Nama channel placeholder -->
        <View
            android:layout_width="160dp"
            android:layout_height="16dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_skeleton" />

        <!-- Subtitle / grup placeholder -->
        <View
            android:layout_width="100dp"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_skeleton"
            android:alpha="0.6" />

        <!-- Progress bar placeholder -->
        <View
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_skeleton"
            android:alpha="0.4" />

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>
