<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OrbixTV" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="bottomSheetDialogTheme">@style/Theme.OrbixTV.BottomSheet</item>
    </style>

    <style name="Theme.OrbixTV.BottomSheet" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/OrbixBottomSheetStyle</item>
    </style>

    <style name="OrbixBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/bg_card</item>
        <item name="shapeAppearance">@style/OrbixBottomSheetShape</item>
    </style>

    <style name="OrbixBottomSheetShape" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>

    <style name="Theme.OrbixTV.Splash" parent="Theme.OrbixTV">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.OrbixTV.Player" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>
</resources>
